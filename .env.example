# ============================================================
# PlanPlate — Frontend environment variables
#
# Copy this file to .env.local and fill in the values.
# Variables prefixed with VITE_ are exposed to the browser
# via import.meta.env. Never put secrets here.
# ============================================================

# Supabase project URL (visible in Supabase > Settings > API)
# For local dev: http://127.0.0.1:54331 (or proxied through Netlify as http://localhost:8888)
VITE_SUPABASE_URL=http://127.0.0.1:54331

# Supabase publishable/anon key — safe to expose in the browser;
# Row Level Security protects the data.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
